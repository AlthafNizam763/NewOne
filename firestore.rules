rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // registrations collection
    match /registrations/{email} {
      // Allow anybody (even unauthenticated) to check email uniqueness and create a registration
      allow read, create: if true;
      allow update, delete: if isAuthenticated();
    }

    // users collection
    match /users/{userId} {
      // Anyone can read user info (unauthenticated check for username, authenticated search for partner)
      allow read: if true;
      // Allow writing to user profile if authenticated
      allow write: if isAuthenticated();
    }

    // pairs collection
    match /pairs/{pairId} {
      // Anyone can create pairs during registration, authenticated users can read/write
      allow read, write: if true;
    }

    // chat_rooms collection
    match /chat_rooms/{roomId} {
      // Must be authenticated and a participant to read/write the chat room
      allow read, write: if isAuthenticated() && 
        (request.auth.uid in resource.data.participants || 
         request.auth.uid in request.resource.data.participants);

      // messages subcollection
      match /messages/{messageId} {
        // Must be authenticated and a participant in the parent chat room
        allow read, write: if isAuthenticated() && 
          request.auth.uid in get(/databases/$(database)/documents/chat_rooms/$(roomId)).data.participants;
      }
    }
  }
}
